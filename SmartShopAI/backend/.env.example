APP_NAME=SmartShopAI Backend
APP_ENV=development
HOST=127.0.0.1
PORT=8000
DATABASE_PATH=./data/smartshop.db
DATASET_PATH=../app/ecommerce_agent_dataset
CORS_ORIGINS=*
UPLOAD_DIR=./data/uploads
POE_API_KEY=your_poe_api_key_here
POE_BASE_URL=https://api.poe.com/v1
LLM_MODEL=gemini-3.5-flash
# Legacy fallback for older local env files.
QWEN_MODEL=
LLM_TIMEOUT_SECONDS=25
ASR_PROVIDER=none
ASR_BASE_URL=
ASR_API_KEY=your_asr_api_key_here
ASR_MODEL=whisper-1
ASR_TIMEOUT_SECONDS=30
VECTOR_BACKEND=milvus
VECTOR_DIMENSIONS=1024
EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=http://localhost:8080/v1
EMBEDDING_API_KEY=empty
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSIONS=1024
EMBEDDING_SEND_DIMENSIONS=false
EMBEDDING_TIMEOUT_SECONDS=30
QDRANT_URL=
QDRANT_COLLECTION=smartshop_products
QDRANT_API_KEY=your_qdrant_api_key_here
MILVUS_BASE_URL=http://localhost:19530
MILVUS_COLLECTION=smartshop_products
MILVUS_PRIMARY_FIELD=product_id
MILVUS_VECTOR_FIELD=vector
MILVUS_METRIC_TYPE=COSINE
MILVUS_DB_NAME=
MILVUS_TOKEN=root:Milvus
GRAPH_BACKEND=none
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=your_neo4j_password_here
