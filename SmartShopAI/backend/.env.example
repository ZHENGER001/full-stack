APP_NAME=SmartShopAI Backend
APP_ENV=development
HOST=127.0.0.1
PORT=8000
DATABASE_PATH=./data/smartshop.db
DATASET_PATH=../app/ecommerce_agent_dataset
CORS_ORIGINS=*
UPLOAD_DIR=./data/uploads

# Poe / Qwen OpenAI-compatible ChatCompletion
POE_API_KEY=sk-poe-r7a3ojDH_0-QfpHUvoCNbOCHvb87NHs2PLio8ARSHeo
POE_BASE_URL=https://api.poe.com/v1
QWEN_MODEL=qwen3.6-plus
LLM_PROVIDER=poe
LLM_TIMEOUT_SECONDS=8
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=

# Embedding providers: local, openai-compatible, dashscope, ollama
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
DENSE_SEARCH_MODE=auto
DASHSCOPE_API_KEY=
DASHSCOPE_EMBEDDING_URL=
OLLAMA_EMBEDDING_URL=http://127.0.0.1:11434/api/embeddings

# Milvus vector search
MILVUS_URI=
MILVUS_TOKEN=
MILVUS_COLLECTION=smartshop_products

# Neo4j product graph
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
